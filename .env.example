PORT=3000
HOST=0.0.0.0
NODE_ENV=development
# Se WEBHOOK_SECRET foi exposto (ex.: HTML do simulador), gera um novo valor e atualiza na Vercel + redeploy.
# Sessões: em produção define Upstash (Redis via HTTPS) — https://upstash.com/
# O POST /webhook devolve sempre `sessionBackend`: "upstash" | "memory" (simulador mostra o estado).
# Simulador HTML envia `simulator: true` + `clientSession` (memória na página; F5 recomeça) — sem depender de Redis.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Opcional: timeout por comando Redis em ms (predefinido 15000).
# UPSTASH_REDIS_TIMEOUT_MS=15000
#
# Opcional: pasta para PDFs/SVGs (predefinido: ./storage em dev; em VERCEL usa /tmp/... automaticamente).
# PALLET_STORAGE_PATH=
#
# Vercel: webhook → https://<teu-projeto>.vercel.app/webhook
# Simulador: /simulator → /simulator.html (build gera public/simulator.html a partir de simulator.source.html)
# npm run build: tsc + scripts/sync-simulator-static.cjs
#
# PDF V2: overlays de debug (bbox, eixos, cores 3D) + log layoutSolution no console.
# DEBUG_PDF=true
#
# Geração do PDF no mesmo pedido HTTP que *Gerar projeto* (comportamento antigo).
# Sem isto, o primeiro POST só devolve a mensagem de espera e `resumePdfGeneration: true`;
# o integrador WhatsApp deve enviar de seguida outro POST com `resumePdfGeneration: true`.
# PALLET_BOT_INLINE_PDF=true
