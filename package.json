{
  "name": "pallet-bot-whatsapp",
  "version": "1.0.0",
  "description": "Bot de WhatsApp para Projeto Porta-Paletes baseado em state machine",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && node scripts/sync-simulator-static.cjs",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "vercel:dev": "npx vercel dev",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "pdf:test": "tsx scripts/generate-test-pdfs.ts",
    "pdf:test:audit": "LAYOUT_AUDIT_LOG=1 tsx scripts/generate-test-pdfs.ts"
  },
  "keywords": [
    "whatsapp",
    "bot",
    "pallet",
    "state-machine"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=20 <26"
  },
  "overrides": {
    "test-exclude": "7.0.2"
  },
  "dependencies": {
    "@upstash/redis": "^1.36.0",
    "fastify": "^4.24.3",
    "pdfkit": "^0.14.0",
    "serverless-http": "^3.2.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.3",
    "@types/pdfkit": "^0.13.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.5.0",
    "jest": "^30.3.0",
    "pdf-lib": "^1.17.1",
    "prettier": "^3.7.4",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1"
  }
}
